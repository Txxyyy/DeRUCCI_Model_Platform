#!/bin/bash
# Claude Context Monitor - 快速查看context使用量
# 使用方法: ./ctx 或 source ctx

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   Claude Code Context Monitor          ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
echo ""

# 使用Claude Code的context命令
CLAUDECODE= claude --context
